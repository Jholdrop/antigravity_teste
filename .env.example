# Firebase client SDK - usado pelo Vite no navegador.
# Copie para .env no desenvolvimento local e cadastre os mesmos valores no Netlify.

VITE_FIREBASE_API_KEY=sua_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=seu_auth_domain_aqui
VITE_FIREBASE_PROJECT_ID=seu_project_id_aqui
VITE_FIREBASE_STORAGE_BUCKET=seu_storage_bucket_aqui
VITE_FIREBASE_MESSAGING_SENDER_ID=seu_sender_id_aqui
VITE_FIREBASE_APP_ID=seu_app_id_aqui
VITE_FIREBASE_DATABASE_ID=default

# Quiz server-side - mantenha fora do front-end.
# Use uma string aleatoria com 32+ caracteres.
QUIZ_SECRET=troque-por-uma-chave-aleatoria-com-mais-de-32-caracteres

# Firebase Admin SDK - usado apenas pelas Netlify Functions para salvar capturas validadas.
# Crie uma Service Account no Firebase/Google Cloud e cole estes valores no Netlify.
FIREBASE_PROJECT_ID=seu_project_id_aqui
FIREBASE_DATABASE_ID=default
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@seu_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=cole_o_valor_private_key_do_json_da_service_account
